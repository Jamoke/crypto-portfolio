{
  "title": "Polymarket — Scanner & Whale Analytics",
  "uid": "polymarket-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "description": "Polymarket service observability: market scanner, opportunities, simulated positions, and on-chain whale analytics (Phase A). Extended in Phase B with reject reasons, Kelly sizing, and exit triggers.",
  "panels": [

    { "type": "row", "id": 100, "title": "Scanner Summary", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 101, "type": "stat", "title": "Markets scanned (1h)",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "expr": "increase(polymarket_markets_scanned_total[1h])",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 102, "type": "stat", "title": "Opportunities (24h)",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "blue", "value": null },
          { "color": "green", "value": 1 }
        ] } } },
      "targets": [{ "expr": "increase(polymarket_opportunities_total[24h])",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 103, "type": "stat", "title": "Open simulated positions",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{ "expr": "polymarket_positions_open",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 104, "type": "stat", "title": "Opportunity rate (per 100 scans)",
      "description": "Rough yield of the scanner — very high values warrant checking for prompt/config drift.",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "none",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "red", "value": 25 }
        ] } } },
      "targets": [{
        "expr": "100 * increase(polymarket_opportunities_total[24h]) / clamp_min(increase(polymarket_markets_scanned_total[24h]), 1)",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    { "type": "row", "id": 200, "title": "Whale Analytics (Phase A)", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 201, "type": "stat", "title": "Whales tracked",
      "description": "Count of wallets meeting min_trades AND min_win_rate AND min_pnl thresholds from strategy_config.yaml.",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "green", "value": 10 }
        ] } } },
      "targets": [{ "expr": "polymarket_whales_tracked",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 202, "type": "stat", "title": "Events consumed (last refresh)",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "expr": "polymarket_whale_events_seen",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 203, "type": "stat", "title": "Hours since last refresh",
      "description": "Warn if this exceeds the configured refresh_hours (default 24h).",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "h",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 26 },
          { "color": "red", "value": 48 }
        ] } } },
      "targets": [{
        "expr": "(time() - polymarket_whale_refresh_last_success_timestamp) / 3600",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 204, "type": "stat", "title": "Refresh failures (24h)",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 3 }
        ] } } },
      "targets": [{ "expr": "increase(polymarket_whale_refresh_failures_total[24h])",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 210, "type": "timeseries", "title": "Whale refresh duration",
      "description": "p50/p95 of whale refresh wall-clock time. Watch for growth indicating subgraph slowness or event-volume creep.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s",
        "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(polymarket_whale_refresh_duration_seconds_bucket[6h])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(polymarket_whale_refresh_duration_seconds_bucket[6h])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 211, "type": "timeseries", "title": "Whales tracked over time",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [{ "expr": "polymarket_whales_tracked",
        "legendFormat": "whales",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },

    { "type": "row", "id": 300, "title": "Scanner Rejections (Phase B)", "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 301, "type": "piechart", "title": "Reject reasons (24h)",
      "description": "Why candidate markets were rejected before reaching Claude. Heavy 'depth' or 'volume' skew means tunables in strategy_config.yaml may be too strict.",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut" },
      "targets": [{
        "expr": "sum by (reason) (increase(polymarket_rejects_total[24h]))",
        "legendFormat": "{{reason}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "id": 302, "type": "timeseries", "title": "Reject rate over time",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "targets": [{
        "expr": "sum by (reason) (rate(polymarket_rejects_total[1h]))",
        "legendFormat": "{{reason}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },

    { "type": "row", "id": 400, "title": "Sizing & Whale Concurrence (Phase B)", "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 401, "type": "bargauge", "title": "Kelly fraction distribution",
      "description": "Histogram of f* values at opportunity-creation time. Quarter-Kelly cap is 0.25 — any bucket at 0.25 represents capped positions.",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "continuous-GrYlRd" } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal" },
      "targets": [{
        "expr": "sum by (le) (increase(polymarket_kelly_fraction_bucket[7d]))",
        "format": "heatmap",
        "legendFormat": "{{le}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "id": 402, "type": "stat", "title": "Whale concurrences (7d)",
      "description": "Opportunities where at least one tracked whale holds the same side. Currently a feature flag, not an auto-trade trigger.",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{ "expr": "increase(polymarket_whale_concurrences_total[7d])",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 403, "type": "stat", "title": "Whale concurrence rate",
      "description": "Share of opportunities over the last 7d that had whale agreement.",
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "blue", "value": null },
          { "color": "green", "value": 0.1 }
        ] } } },
      "targets": [{
        "expr": "increase(polymarket_whale_concurrences_total[7d]) / clamp_min(increase(polymarket_opportunities_total[7d]), 1)",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    { "type": "row", "id": 500, "title": "Exit Monitor (Phase B)", "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 501, "type": "piechart", "title": "Exit reasons (30d)",
      "description": "How simulated positions closed. Heavy 'stale_thesis' means Claude's probability estimates are not moving the market — a Phase C calibration signal.",
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut" },
      "targets": [{
        "expr": "sum by (reason) (increase(polymarket_exits_total[30d]))",
        "legendFormat": "{{reason}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },
    {
      "id": 502, "type": "timeseries", "title": "Exits by reason over time",
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [{
        "expr": "sum by (reason) (increase(polymarket_exits_total[1d]))",
        "legendFormat": "{{reason}}",
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }]
    },

    { "type": "row", "id": 900, "title": "Whale roster & positions (live from SQLite)", "gridPos": { "x": 0, "y": 45, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 901, "type": "table", "title": "Top whales by PnL",
      "description": "Live roster from polymarket.db::whales. Refreshed every 24h by the whale tracker. Addresses are Polygon wallets; click through to polygonscan for on-chain history.",
      "gridPos": { "x": 0, "y": 46, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "win_rate" },
            "properties": [{ "id": "unit", "value": "percentunit" }] },
          { "matcher": { "id": "byName", "options": "total_pnl" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "avg_hold_hours" },
            "properties": [{ "id": "unit", "value": "h" }] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": true, "reducer": ["count"], "fields": ["address"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "polymarket-sqlite" },
        "queryType": "table",
        "rawQueryText": "SELECT address, trades, ROUND(win_rate, 3) AS win_rate, ROUND(total_pnl, 2) AS total_pnl, ROUND(avg_hold_hours, 1) AS avg_hold_hours, last_trade_at FROM whales ORDER BY total_pnl DESC LIMIT 20",
        "queryText": "SELECT address, trades, ROUND(win_rate, 3) AS win_rate, ROUND(total_pnl, 2) AS total_pnl, ROUND(avg_hold_hours, 1) AS avg_hold_hours, last_trade_at FROM whales ORDER BY total_pnl DESC LIMIT 20",
        "timeColumns": []
      }]
    },
    {
      "id": 902, "type": "table", "title": "Open simulated positions",
      "description": "Live from polymarket.db::positions where closed_at IS NULL. All rows have simulation=1 — enforced as a literal in publish_opportunity() (see tests/test_no_live_orders.py).",
      "gridPos": { "x": 12, "y": 46, "w": 12, "h": 10 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "entry_price" },
            "properties": [{ "id": "unit", "value": "percentunit" }] },
          { "matcher": { "id": "byName", "options": "amount_usd" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "kelly_fraction" },
            "properties": [{ "id": "unit", "value": "percentunit" }] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": true, "reducer": ["count"], "fields": ["id"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "polymarket-sqlite" },
        "queryType": "table",
        "rawQueryText": "SELECT id, SUBSTR(market_id, 1, 16) AS market_id, side, ROUND(entry_price, 3) AS entry_price, ROUND(amount_usd, 2) AS amount_usd, ROUND(kelly_fraction, 4) AS kelly_fraction, whale_concurrence, opened_at FROM positions WHERE closed_at IS NULL AND simulation=1 ORDER BY opened_at DESC LIMIT 50",
        "queryText": "SELECT id, SUBSTR(market_id, 1, 16) AS market_id, side, ROUND(entry_price, 3) AS entry_price, ROUND(amount_usd, 2) AS amount_usd, ROUND(kelly_fraction, 4) AS kelly_fraction, whale_concurrence, opened_at FROM positions WHERE closed_at IS NULL AND simulation=1 ORDER BY opened_at DESC LIMIT 50",
        "timeColumns": []
      }]
    },

    {
      "id": 903, "type": "table", "title": "Closed positions — last 30 days",
      "description": "Realized outcomes for simulated positions. exit_reason pairs with the Prometheus 'Exit reasons' pie chart above, but with per-position PnL that Prometheus can't store.",
      "gridPos": { "x": 0, "y": 56, "w": 18, "h": 10 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "entry_price" },
            "properties": [{ "id": "unit", "value": "percentunit" }] },
          { "matcher": { "id": "byName", "options": "exit_price" },
            "properties": [{ "id": "unit", "value": "percentunit" }] },
          { "matcher": { "id": "byName", "options": "amount_usd" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "pnl_usd" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
              { "id": "color", "value": { "mode": "continuous-RdYlGr" } }
            ] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": true, "reducer": ["sum"], "fields": ["pnl_usd"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "polymarket-sqlite" },
        "queryType": "table",
        "rawQueryText": "SELECT SUBSTR(market_id, 1, 16) AS market_id, side, ROUND(entry_price, 3) AS entry_price, ROUND(exit_price, 3) AS exit_price, ROUND(amount_usd, 2) AS amount_usd, ROUND(pnl_usd, 2) AS pnl_usd, exit_reason, opened_at, closed_at FROM positions WHERE closed_at IS NOT NULL AND simulation=1 AND closed_at >= datetime('now', '-30 days') ORDER BY closed_at DESC LIMIT 100",
        "queryText": "SELECT SUBSTR(market_id, 1, 16) AS market_id, side, ROUND(entry_price, 3) AS entry_price, ROUND(exit_price, 3) AS exit_price, ROUND(amount_usd, 2) AS amount_usd, ROUND(pnl_usd, 2) AS pnl_usd, exit_reason, opened_at, closed_at FROM positions WHERE closed_at IS NOT NULL AND simulation=1 AND closed_at >= datetime('now', '-30 days') ORDER BY closed_at DESC LIMIT 100",
        "timeColumns": []
      }]
    },
    {
      "id": 904, "type": "stat", "title": "Simulated PnL (30d)",
      "description": "Sum of pnl_usd across all closed simulated positions in the last 30 days. Sanity-check against the exit-reason mix — heavy stale_thesis with positive PnL is suspicious.",
      "gridPos": { "x": 18, "y": 56, "w": 6, "h": 5 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 0 },
          { "color": "green", "value": 0.01 }
        ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "pnl_30d" }, "colorMode": "background" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "polymarket-sqlite" },
        "queryType": "table",
        "rawQueryText": "SELECT COALESCE(SUM(pnl_usd), 0) AS pnl_30d FROM positions WHERE closed_at IS NOT NULL AND simulation=1 AND closed_at >= datetime('now', '-30 days')",
        "queryText": "SELECT COALESCE(SUM(pnl_usd), 0) AS pnl_30d FROM positions WHERE closed_at IS NOT NULL AND simulation=1 AND closed_at >= datetime('now', '-30 days')",
        "timeColumns": []
      }]
    },
    {
      "id": 905, "type": "stat", "title": "Win rate (30d, closed)",
      "description": "Share of closed simulated positions with pnl_usd > 0 in the last 30 days.",
      "gridPos": { "x": 18, "y": 61, "w": 6, "h": 5 },
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 0.5 },
          { "color": "green", "value": 0.55 }
        ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "win_rate" }, "colorMode": "background" },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "polymarket-sqlite" },
        "queryType": "table",
        "rawQueryText": "SELECT CAST(SUM(CASE WHEN pnl_usd > 0 THEN 1 ELSE 0 END) AS REAL) / NULLIF(COUNT(*), 0) AS win_rate FROM positions WHERE closed_at IS NOT NULL AND simulation=1 AND closed_at >= datetime('now', '-30 days')",
        "queryText": "SELECT CAST(SUM(CASE WHEN pnl_usd > 0 THEN 1 ELSE 0 END) AS REAL) / NULLIF(COUNT(*), 0) AS win_rate FROM positions WHERE closed_at IS NOT NULL AND simulation=1 AND closed_at >= datetime('now', '-30 days')",
        "timeColumns": []
      }]
    },

    {
      "id": 906, "type": "text", "title": "CLI inspection (if Grafana is unavailable)",
      "gridPos": { "x": 0, "y": 66, "w": 24, "h": 4 },
      "options": {
        "mode": "markdown",
        "content": "Same data, via the shell on the Pi:\n\n```bash\n# Top 20 from Redis (pipe through polymarket where jq is installed)\ndocker compose exec redis redis-cli GET signals:polymarket:whales:summary \\\n  | docker compose exec -T polymarket jq '.top[0:20]'\n\n# Open positions\ndocker compose exec polymarket sqlite3 /app/data/polymarket.db \\\n    'SELECT id, market_id, side, entry_price, amount_usd, kelly_fraction, whale_concurrence, opened_at FROM positions WHERE closed_at IS NULL AND simulation=1 ORDER BY opened_at DESC'\n```\n\nAll rows are `simulation=1` — enforced as a literal in `publish_opportunity()`."
      }
    }
  ],
  "templating": {
    "list": [{
      "name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus",
      "hide": 2, "current": { "text": "Prometheus", "value": "prometheus" }
    }]
  }
}
