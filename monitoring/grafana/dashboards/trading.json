{
  "title": "Crypto Portfolio",
  "uid": "crypto-portfolio-main",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [

    { "type": "row", "id": 100, "title": "Portfolio Overview", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 1, "type": "stat", "title": "Total Trades",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } },
      "targets": [{ "expr": "crypto_trades_total", "legendFormat": "Trades",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto",
        "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat", "title": "Realized P&L (USD)",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "green", "value": 0 }
        ] } } },
      "targets": [{ "expr": "crypto_realized_pnl_usd_total",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 3, "type": "stat", "title": "Win Rate",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit",
        "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": 0 },
          { "color": "yellow", "value": 0.4 },
          { "color": "green", "value": 0.6 }
        ] } } },
      "targets": [{ "expr": "crypto_winning_trades / (crypto_winning_trades + crypto_losing_trades)",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "textMode": "auto" }
    },
    {
      "id": 4, "type": "stat", "title": "Gas Spent (USD)",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD",
        "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [{ "expr": "crypto_gas_spent_usd_total",
        "datasource": { "type": "prometheus", "uid": "prometheus" } }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background", "textMode": "auto" }
