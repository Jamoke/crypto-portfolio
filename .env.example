# ============================================================
#  Crypto Portfolio — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git (it's in .gitignore)
# ============================================================

# ---- Timezone ----
TIMEZONE=America/Los_Angeles

# ---- Claude / Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ---- Data APIs (both have free tiers to start) ----
COINGECKO_API_KEY=          # Optional: free tier works without key
LUNARCRUSH_API_KEY=         # Optional: free tier available

# ---- News feed API (feeds the news_collector -> claude_analyst chain) ----
# CryptoCompare News: 100k req/mo free, works unauthenticated but rate-limited.
# Get a key at https://www.cryptocompare.com/cryptopian/api-keys
# (CryptoPanic support was removed April 2026 — free Developer API retired.)
CRYPTOCOMPARE_API_KEY=
# How often the collector polls. 1800s = every 30 min.
NEWS_POLL_INTERVAL=1800

# ---- Wallet ----
WALLET_ADDRESS=0x0000000000000000000000000000000000000000
# WALLET_PRIVATE_KEY — required for live trading (Phase 3+)
# WARNING: This grants full control of the wallet. Keep .env out of git.
# Use a dedicated trading wallet, never your main cold storage wallet.
WALLET_PRIVATE_KEY=

# ---- Blockchain RPC URLs ----
# Free options: Alchemy (https://alchemy.com) or Infura (https://infura.io)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ---- DEX Aggregator ----
ONEINCH_API_KEY=            # Get free at https://portal.1inch.dev

# ---- Simulation Mode ----
# true = analyze and log only, no real transactions (Phase 1 default)
# false = live execution (only set after thorough testing!)
SIMULATION_MODE=true

# ---- TradingView Webhook ----
# Choose any random secret string — add it to your TV alert webhook URL
# e.g. https://YOUR_PI_IP:8443/webhook?secret=YOURSECRETHERE
TV_WEBHOOK_SECRET=replace_with_random_secret_string

# ---- Telegram Bot ----
# Create bot: message @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Email Digest ----
# Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_here    # 16-char App Password, not your Gmail password
DIGEST_RECIPIENT=your@gmail.com
DIGEST_HOUR=8                           # Hour to send digest (24h, local time)
DIGEST_SECRET=replace_with_random_secret_for_approval_emails

# ---- Freqtrade ----
FREQTRADE_USERNAME=admin
FREQTRADE_PASSWORD=changeme_secure_password
# JWT and WS secrets — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FREQTRADE_JWT_SECRET=replace_with_random_64char_hex
FREQTRADE_WS_TOKEN=replace_with_random_64char_hex
FREQTRADE_SCALP_JWT_SECRET=replace_with_different_random_64char_hex
FREQTRADE_SCALP_WS_TOKEN=replace_with_different_random_64char_hex
# FreqAI bot (Plan 5 — only needed when running with --profile freqai)
FREQTRADE_FREQAI_JWT_SECRET=replace_with_another_random_64char_hex
FREQTRADE_FREQAI_WS_TOKEN=replace_with_another_random_64char_hex

# ---- Network ----
# Your Raspberry Pi's local IP address (used for CORS in Freqtrade configs)
PI_LOCAL_IP=192.168.1.100

# ---- Grafana ----
GRAFANA_PASSWORD=changeme_secure_password

# ---- Polymarket (Plan 4.5 — leave blank until implemented) ----
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=
